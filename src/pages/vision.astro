---
import Layout from '../layouts/Layout.astro';
import "../styles.css";
---

<Layout>
    <main class="p-8 max-w-4xl mx-auto">
        <h1 class="text-3xl font-bold text-blue-800 mb-4">Vision</h1>

        <section class="mb-6">
            <p class="text-gray-700">
                AURA envisions a future where AI-generated and AI-assisted content is transparently acknowledged, fairly attributed, and seamlessly integrated into academic, industrial, and creative practices — without compromising human authorship, originality, or responsibility.
            </p>
        </section>

        <section class="mb-6">
            <h2 class="text-xl font-semibold text-gray-800 mb-2">Core Principles</h2>
            <ul class="list-disc list-inside text-gray-700">
                <li><strong>Transparency:</strong> Users deserve to know when and how AI was involved.</li>
                <li><strong>Attribution:</strong> Tools and systems must be cited and referenced responsibly.</li>
                <li><strong>Reproducibility:</strong> Metadata must allow tracing and re-generation when possible.</li>
                <li><strong>Interoperability:</strong> The protocol should adapt to different formats, platforms, and disciplines.</li>
            </ul>
        </section>
    </main>
</Layout>
